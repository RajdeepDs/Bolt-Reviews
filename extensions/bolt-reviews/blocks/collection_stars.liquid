{% comment %}
  Collection Stars Block
  Displays a simple star rating badge for products on collection pages
{% endcomment %}

{%- assign rating_value = product.metafields.bolt_reviews.rating.value | default: 0 -%}
{%- assign review_count = product.metafields.bolt_reviews.review_count.value | default: 0 -%}
{%- assign rating_ceil = rating_value | ceil -%}
{%- assign rating_decimal = rating_value | modulo: 1 -%}

{%- if review_count > 0 or block.settings.show_empty_stars -%}
<div class="bolt-collection-stars" style="margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px 0;">
  <div class="stars-display" aria-label="{{ rating_value }} out of 5 stars">
    {%- for i in (1..5) -%}
      {%- if i <= rating_value -%}
        <span class="star-icon filled" style="color: {{ block.settings.star_color }};">★</span>
      {%- elsif i == rating_ceil and rating_decimal > 0 -%}
        <span class="star-icon half" style="color: {{ block.settings.star_color }};">★</span>
      {%- else -%}
        <span class="star-icon empty" style="color: #e0e0e0;">★</span>
      {%- endif -%}
    {%- endfor -%}
  </div>
  {%- if block.settings.show_count and review_count > 0 -%}
    <span class="review-count" style="color: {{ block.settings.text_color }};">({{ review_count }})</span>
  {%- endif -%}
</div>
{%- endif -%}

<style>
  .bolt-collection-stars {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: {{ block.settings.font_size }}px;
  }
  .bolt-collection-stars .stars-display {
    display: flex;
    gap: 1px;
    letter-spacing: normal;
  }
  .bolt-collection-stars .star-icon {
    line-height: 1;
  }
  .bolt-collection-stars .review-count {
    font-size: 0.9em;
    margin-left: 2px;
  }
</style>

{% schema %}
{
  "name": "Collection Stars",
  "target": "section",
  "templates": ["collection", "search", "product"],
  "settings": [
    {
      "type": "color",
      "id": "star_color",
      "label": "Star Color",
      "default": "#FFB800"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Star Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show Review Count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_empty_stars",
      "label": "Show Empty Stars if No Reviews",
      "default": false
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 4
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 8
    }
  ]
}
{% endschema %}
